import QtQuick 2.15
import QtQuick.Controls 2.15
import QtQuick.Layouts 1.15
import BasicComponents 1.0
import IndustrialComponents 1.0
import ChartComponents 1.0

ApplicationWindow {
    id: mainWindow
    visible: true
    width: 1400
    height: 900
    title: "Industrial SCADA System"

    // Core modules
    property var tagManager: null
    property var modbusDriver: null
    property var dataProcessor: null
    property var currentLayout: []

    // System status
    property bool systemOnline: false
    property int activeTags: 0
    property int activeConnections: 0
    property int alarmCount: 0

    // Drag and drop helper
    DragAndDropHelper {
        id: dragDropHelper
    }

    // Title bar
    Rectangle {
        id: titleBar
        anchors.top: parent.top
        anchors.left: parent.left
        anchors.right: parent.right
        height: 60
        color: "#1a237e"
        border.color: "#0d47a1"
        border.width: 1

        RowLayout {
            anchors.fill: parent
            anchors.margins: 10
            spacing: 20

            // System logo and title
            RowLayout {
                spacing: 10

                Rectangle {
                    width: 40
                    height: 40
                    color: "#4caf50"
                    radius: 8

                    Text {
                        anchors.centerIn: parent
                        text: "S"
                        font.bold: true
                        font.pixelSize: 24
                        color: "white"
                    }
                }

                ColumnLayout {
                    spacing: 2

                    Text {
                        text: "Industrial SCADA System"
                        font.bold: true
                        font.pixelSize: 18
                        color: "white"
                    }

                    Text {
                        text: "v1.0.0"
                        font.pixelSize: 12
                        color: "#bbdefb"
                    }
                }
            }

            // System status indicators
            RowLayout {
                spacing: 15

                RowLayout {
                    spacing: 5

                    Rectangle {
                        width: 10
                        height: 10
                        radius: 5
                        color: systemOnline ? "#4caf50" : "#f44336"
                    }

                    Text {
                        text: systemOnline ? "Online" : "Offline"
                        color: "white"
                        font.pixelSize: 12
                    }
                }

                RowLayout {
                    spacing: 5

                    Rectangle {
                        width: 10
                        height: 10
                        radius: 5
                        color: activeTags > 0 ? "#4caf50" : "#9e9e9e"
                    }

                    Text {
                        text: "Tags: " + activeTags
                        color: "white"
                        font.pixelSize: 12
                    }
                }

                RowLayout {
                    spacing: 5

                    Rectangle {
                        width: 10
                        height: 10
                        radius: 5
                        color: activeConnections > 0 ? "#4caf50" : "#9e9e9e"
                    }

                    Text {
                        text: "Connections: " + activeConnections
                        color: "white"
                        font.pixelSize: 12
                    }
                }

                RowLayout {
                    spacing: 5

                    Rectangle {
                        width: 10
                        height: 10
                        radius: 5
                        color: alarmCount > 0 ? "#ff9800" : "#4caf50"
                    }

                    Text {
                        text: "Alarms: " + alarmCount
                        color: "white"
                        font.pixelSize: 12
                    }
                }
            }

            // System time
            Text {
                id: systemTime
                color: "white"
                font.pixelSize: 14
                Layout.alignment: Qt.AlignRight
            }
        }
    }

    // Update system time
    Timer {
        interval: 1000
        running: true
        repeat: true
        onTriggered: {
            var date = new Date();
            systemTime.text = date.toLocaleString();
        }
    }

    // Main content area
    Rectangle {
        id: mainContent
        anchors.top: titleBar.bottom
        anchors.bottom: parent.bottom
        anchors.left: parent.left
        anchors.right: parent.right
        color: "#f5f5f5"

        // Tab view for main interface
        TabView {
            anchors.fill: parent
            tabPosition: TabView.TabPosition.Top
            tabBar {
                height: 40
                font.pixelSize: 14
                font.bold: true
                
                TabButton {
                    text: "Dashboard"
                    width: 120
                    height: 40
                }
                
                TabButton {
                    text: "Configuration"
                    width: 120
                    height: 40
                }
                
                TabButton {
                    text: "Tag Management"
                    width: 140
                    height: 40
                }
                
                TabButton {
                    text: "Alarms"
                    width: 100
                    height: 40
                }
                
                TabButton {
                    text: "Reports"
                    width: 100
                    height: 40
                }
                
                TabButton {
                    text: "System"
                    width: 100
                    height: 40
                }
            }

        // Dashboard tab
        Tab {
            title: "Dashboard"

            GridLayout {
                anchors.fill: parent
                anchors.margins: 10
                columns: 3
                rowSpacing: 10
                columnSpacing: 10

                // System status dashboard
                GroupBox {
                    title: "System Status"
                    Layout.fillWidth: true
                    Layout.fillHeight: true
                    Layout.rowSpan: 2

                    ColumnLayout {
                        anchors.fill: parent
                        spacing: 15

                        RowLayout {
                            spacing: 15
                            Layout.fillWidth: true

                            // System status card
                            Rectangle {
                                width: 120
                                height: 80
                                radius: 8
                                color: systemOnline ? "#e8f5e9" : "#ffebee"
                                border.color: systemOnline ? "#4caf50" : "#f44336"
                                border.width: 1

                                ColumnLayout {
                                    anchors.centerIn: parent
                                    spacing: 5

                                    Text {
                                        text: systemOnline ? "ONLINE" : "OFFLINE"
                                        font.bold: true
                                        color: systemOnline ? "#2e7d32" : "#c62828"
                                    }

                                    Text {
                                        text: "System"
                                        font.pixelSize: 12
                                        color: "#616161"
                                    }
                                }
                            }

                            // Modbus status card
                            Rectangle {
                                width: 120
                                height: 80
                                radius: 8
                                color: modbusDriver && modbusDriver.isConnected() ? "#e8f5e9" : "#ffebee"
                                border.color: modbusDriver && modbusDriver.isConnected() ? "#4caf50" : "#f44336"
                                border.width: 1

                                ColumnLayout {
                                    anchors.centerIn: parent
                                    spacing: 5

                                    Text {
                                        text: modbusDriver && modbusDriver.isConnected() ? "CONNECTED" : "DISCONNECTED"
                                        font.bold: true
                                        color: modbusDriver && modbusDriver.isConnected() ? "#2e7d32" : "#c62828"
                                    }

                                    Text {
                                        text: "Modbus TCP"
                                        font.pixelSize: 12
                                        color: "#616161"
                                    }
                                }
                            }

                            // Data collection status card
                            Rectangle {
                                width: 120
                                height: 80
                                radius: 8
                                color: dataProcessor ? "#e8f5e9" : "#ffebee"
                                border.color: dataProcessor ? "#4caf50" : "#f44336"
                                border.width: 1

                                ColumnLayout {
                                    anchors.centerIn: parent
                                    spacing: 5

                                    Text {
                                        text: dataProcessor ? "ACTIVE" : "INACTIVE"
                                        font.bold: true
                                        color: dataProcessor ? "#2e7d32" : "#c62828"
                                    }

                                    Text {
                                        text: "Data Collection"
                                        font.pixelSize: 12
                                        color: "#616161"
                                    }
                                }
                            }
                        }

                        // System metrics
                        ColumnLayout {
                            spacing: 10
                            Layout.fillWidth: true

                            RowLayout {
                                spacing: 20
                                Layout.fillWidth: true

                                ColumnLayout {
                                    spacing: 2

                                    Text {
                                        text: "Active Tags"
                                        font.pixelSize: 12
                                        color: "#616161"
                                    }

                                    Text {
                                        text: tagManager ? tagManager.getAllTags().length : 0
                                        font.bold: true
                                        font.pixelSize: 24
                                        color: "#1a237e"
                                    }
                                }

                                ColumnLayout {
                                    spacing: 2

                                    Text {
                                        text: "Active Connections"
                                        font.pixelSize: 12
                                        color: "#616161"
                                    }

                                    Text {
                                        text: activeConnections
                                        font.bold: true
                                        font.pixelSize: 24
                                        color: "#1a237e"
                                    }
                                }

                                ColumnLayout {
                                    spacing: 2

                                    Text {
                                        text: "Alarm Count"
                                        font.pixelSize: 12
                                        color: "#616161"
                                    }

                                    Text {
                                        text: alarmCount
                                        font.bold: true
                                        font.pixelSize: 24
                                        color: alarmCount > 0 ? "#f57c00" : "#1a237e"
                                    }
                                }
                            }
                        }

                        // System events log
                        GroupBox {
                            title: "Recent Events"
                            Layout.fillWidth: true
                            Layout.fillHeight: true

                            ListView {
                                id: eventsList
                                anchors.fill: parent
                                model: [
                                    { time: "10:30:45", event: "System started", severity: "info" },
                                    { time: "10:31:22", event: "Modbus TCP connected", severity: "success" },
                                    { time: "10:32:15", event: "Data collection started", severity: "info" },
                                    { time: "10:33:01", event: "Tag updated: TankLevel", severity: "info" },
                                    { time: "10:34:18", event: "Alarm: High pressure", severity: "warning" }
                                ]

                                delegate: RowLayout {
                                    spacing: 10
                                    width: eventsList.width

                                    Text {
                                        text: model.time
                                        width: 80
                                        font.pixelSize: 12
                                        color: "#616161"
                                    }

                                    Text {
                                        text: model.event
                                        Layout.fillWidth: true
                                        font.pixelSize: 12
                                        color: "#212121"
                                    }

                                    Rectangle {
                                        width: 10
                                        height: 10
                                        radius: 5
                                        color: model.severity === "success" ? "#4caf50" : model.severity === "warning" ? "#f57c00" : model.severity === "error" ? "#f44336" : "#2196f3"
                                    }
                                }
                            }
                        }
                    }
                }

                // Process overview
                GroupBox {
                    title: "Process Overview"
                    Layout.fillWidth: true
                    Layout.fillHeight: true

                    GridLayout {
                        anchors.fill: parent
                        anchors.margins: 10
                        columns: 2
                        rowSpacing: 15
                        columnSpacing: 15

                        // Tank level
                        ColumnLayout {
                            spacing: 5

                            Text {
                                text: "Tank Level"
                                font.pixelSize: 12
                                color: "#616161"
                            }

                            Rectangle {
                                width: 100
                                height: 150
                                radius: 4
                                border.color: "#bdbdbd"
                                border.width: 1

                                // Tank visualization
                                Rectangle {
                                    anchors.bottom: parent.bottom
                                    width: parent.width
                                    height: 75 // 50%
                                    color: "#2196f3"
                                    border.color: "#1e88e5"
                                    border.width: 1
                                }

                                Text {
                                    anchors.centerIn: parent
                                    text: "50%"
                                    font.bold: true
                                    color: "#212121"
                                }
                            }
                        }

                        // Motor status
                        ColumnLayout {
                            spacing: 5

                            Text {
                                text: "Motor Status"
                                font.pixelSize: 12
                                color: "#616161"
                            }

                            Motor {
                                width: 100
                                height: 100
                                running: true
                            }
                        }

                        // Valve status
                        ColumnLayout {
                            spacing: 5

                            Text {
                                text: "Valve Status"
                                font.pixelSize: 12
                                color: "#616161"
                            }

                            Valve {
                                width: 100
                                height: 100
                                open: true
                            }
                        }

                        // Pump status
                        ColumnLayout {
                            spacing: 5

                            Text {
                                text: "Pump Status"
                                font.pixelSize: 12
                                color: "#616161"
                            }

                            Pump {
                                width: 100
                                height: 100
                                running: true
                            }
                        }
                    }
                }

                // System trends
                GroupBox {
                    title: "System Trends"
                    Layout.fillWidth: true
                    Layout.fillHeight: true

                    ColumnLayout {
                        anchors.fill: parent
                        spacing: 10

                        // Tank level trend
                        TrendChart {
                            width: parent.width - 20
                            height: 150
                            title: "Tank Level Trend"
                            tagName: tagManager && tagManager.getAllTags().length > 0 ? tagManager.getAllTags()[0].name : ""
                        }

                        // Pressure trend
                        TrendChart {
                            width: parent.width - 20
                            height: 150
                            title: "Pressure Trend"
                            tagName: tagManager && tagManager.getAllTags().length > 1 ? tagManager.getAllTags()[1].name : ""
                        }
                    }
                }


        // Tag Management tab
        Tab {
            title: "Tag Management"

            ColumnLayout {
                anchors.fill: parent
                anchors.margins: 10
                spacing: 10

                // Tag list
                GroupBox {
                    title: "Tags"
                    Layout.fillWidth: true
                    Layout.fillHeight: true

                    TableView {
                        anchors.fill: parent

                        TableViewColumn {
                            role: "name"
                            title: "Name"
                            width: 150
                        }

                        TableViewColumn {
                            role: "group"
                            title: "Group"
                            width: 100
                        }

                        TableViewColumn {
                            role: "value"
                            title: "Value"
                            width: 100
                        }

                        TableViewColumn {
                            role: "description"
                            title: "Description"
                            width: 200
                        }

                        model: tagManager ? tagManager.getAllTags() : []
                    }
                }

                // Tag controls
                RowLayout {
                    Layout.fillWidth: true
                    spacing: 10

                    TextField {
                        id: tagNameInput
                        placeholderText: "Tag Name"
                        Layout.fillWidth: true
                    }

                    TextField {
                        id: tagGroupInput
                        placeholderText: "Group"
                        Layout.fillWidth: true
                    }

                    TextField {
                        id: tagValueInput
                        placeholderText: "Value"
                        Layout.fillWidth: true
                    }

                    TextField {
                        id: tagDescriptionInput
                        placeholderText: "Description"
                        Layout.fillWidth: true
                    }

                    Button {
                        text: "Add Tag"
                        onClicked: {
                            if (tagManager && tagNameInput.text) {
                                tagManager.addTag(
                                    tagNameInput.text,
                                    tagGroupInput.text || "Default",
                                    tagValueInput.text || 0,
                                    tagDescriptionInput.text
                                );
                                // Clear inputs
                                tagNameInput.text = "";
                                tagGroupInput.text = "";
                                tagValueInput.text = "";
                                tagDescriptionInput.text = "";
                            }
                        }
                    }
                }
            }
        }

        // Configuration tab
        Tab {
            title: "Configuration"

            SplitView {
                anchors.fill: parent
                orientation: Qt.Horizontal

                // Left panel - Component Library
                Rectangle {
                    id: componentLibraryPanel
                    width: 250
                    color: "#f5f5f5"
                    border.color: "#e0e0e0"
                    border.width: 1

                    ColumnLayout {
                        anchors.fill: parent
                        anchors.margins: 10
                        spacing: 10

                        Text {
                            text: "Component Library"
                            font.bold: true
                            font.pixelSize: 16
                            color: "#1a237e"
                        }

                        // Basic Components
                        GroupBox {
                            title: "Basic Components"
                            Layout.fillWidth: true

                            ColumnLayout {
                                spacing: 5

                                Button {
                                    text: "Indicator"
                                    onClicked: {
                                        dragDropHelper.startDragFromLibrary("BasicComponents.Indicator", mouse.x, mouse.y);
                                    }
                                }

                                Button {
                                    text: "PushButton"
                                    onClicked: {
                                        dragDropHelper.startDragFromLibrary("BasicComponents.PushButton", mouse.x, mouse.y);
                                    }
                                }

                                Button {
                                    text: "TextLabel"
                                    onClicked: {
                                        dragDropHelper.startDragFromLibrary("BasicComponents.TextLabel", mouse.x, mouse.y);
                                    }
                                }
                            }
                        }

                        // Industrial Components
                        GroupBox {
                            title: "Industrial Components"
                            Layout.fillWidth: true

                            ColumnLayout {
                                spacing: 5

                                Button {
                                    text: "Valve"
                                    onClicked: {
                                        dragDropHelper.startDragFromLibrary("IndustrialComponents.Valve", mouse.x, mouse.y);
                                    }
                                }

                                Button {
                                    text: "Tank"
                                    onClicked: {
                                        dragDropHelper.startDragFromLibrary("IndustrialComponents.Tank", mouse.x, mouse.y);
                                    }
                                }

                                Button {
                                    text: "Motor"
                                    onClicked: {
                                        dragDropHelper.startDragFromLibrary("IndustrialComponents.Motor", mouse.x, mouse.y);
                                    }
                                }

                                Button {
                                    text: "Pump"
                                    onClicked: {
                                        dragDropHelper.startDragFromLibrary("IndustrialComponents.Pump", mouse.x, mouse.y);
                                    }
                                }
                            }
                        }

                        // Chart Components
                        GroupBox {
                            title: "Chart Components"
                            Layout.fillWidth: true

                            ColumnLayout {
                                spacing: 5

                                Button {
                                    text: "TrendChart"
                                    onClicked: {
                                        dragDropHelper.startDragFromLibrary("ChartComponents.TrendChart", mouse.x, mouse.y);
                                    }
                                }

                                Button {
                                    text: "BarChart"
                                    onClicked: {
                                        dragDropHelper.startDragFromLibrary("ChartComponents.BarChart", mouse.x, mouse.y);
                                    }
                                }
                            }
                        }

                        // Layout Controls
                        GroupBox {
                            title: "Layout Controls"
                            Layout.fillWidth: true

                            ColumnLayout {
                                spacing: 5

                                Button {
                                    text: "Clear Canvas"
                                    onClicked: {
                                        // Clear all items from canvas
                                        if (canvas) {
                                            for (let i = canvas.children.length - 1; i >= 0; i--) {
                                                canvas.children[i].destroy();
                                            }
                                        }
                                    }
                                }

                                Button {
                                    text: "Save Layout"
                                    onClicked: {
                                        currentLayout = dragDropHelper.saveLayout();
                                        console.log("Layout saved:", JSON.stringify(currentLayout));
                                    }
                                }

                                Button {
                                    text: "Load Layout"
                                    onClicked: {
                                        if (currentLayout.length > 0) {
                                            dragDropHelper.loadLayout(currentLayout);
                                        }
                                    }
                                }
                            }
                        }
                    }
                }

                // Center panel - Canvas
                Rectangle {
                    id: canvasPanel
                    SplitView.fillWidth: true
                    SplitView.fillHeight: true
                    color: "#ffffff"
                    border.color: "#e0e0e0"
                    border.width: 1

                    ColumnLayout {
                        anchors.fill: parent
                        spacing: 0

                        // Canvas toolbar
                        Rectangle {
                            id: canvasToolbar
                            height: 40
                            Layout.fillWidth: true
                            color: "#f5f5f5"
                            border.bottom.color: "#e0e0e0"
                            border.bottom.width: 1

                            RowLayout {
                                anchors.fill: parent
                                anchors.margins: 5
                                spacing: 10

                                Text {
                                    text: "Canvas"
                                    font.bold: true
                                    color: "#1a237e"
                                }

                                Button {
                                    text: "Select All"
                                    onClicked: {
                                        // Select all items logic
                                    }
                                }

                                Button {
                                    text: "Delete Selected"
                                    onClicked: {
                                        // Delete selected items logic
                                    }
                                }

                                Item {
                                    Layout.fillWidth: true
                                }

                                Text {
                                    text: "Items: " + (canvas ? canvas.children.length : 0)
                                    color: "#616161"
                                }
                            }
                        }

                        // Canvas area
                        Item {
                            id: canvasContainer
                            Layout.fillWidth: true
                            Layout.fillHeight: true

                            Item {
                                id: canvas
                                anchors.fill: parent
                                anchors.margins: 10
                                clip: true

                                // Canvas background with grid
                                Rectangle {
                                    anchors.fill: parent
                                    color: "#ffffff"
                                    border.color: "#e0e0e0"
                                    border.width: 1

                                    // Grid lines
                                    Repeater {
                                        model: 20
                                        Rectangle {
                                            width: parent.width
                                            height: 1
                                            color: "#f0f0f0"
                                            y: index * (parent.height / 20)
                                        }
                                    }

                                    Repeater {
                                        model: 20
                                        Rectangle {
                                            width: 1
                                            height: parent.height
                                            color: "#f0f0f0"
                                            x: index * (parent.width / 20)
                                        }
                                    }
                                }

                                // Initialize drag and drop helper
                                Component.onCompleted: {
                                    dragDropHelper.init(canvas);
                                }
                            }
                        }
                    }
                }

                // Right panel - Component Properties
                Rectangle {
                    id: propertiesPanel
                    width: 300
                    color: "#f5f5f5"
                    border.color: "#e0e0e0"
                    border.width: 1

                    ColumnLayout {
                        anchors.fill: parent
                        anchors.margins: 10
                        spacing: 10

                        Text {
                            text: "Component Properties"
                            font.bold: true
                            font.pixelSize: 16
                            color: "#1a237e"
                        }

                        // Selected component info
                        GroupBox {
                            title: "Selected Component"
                            Layout.fillWidth: true

                            ColumnLayout {
                                spacing: 5

                                Text {
                                    id: selectedComponentText
                                    text: "No component selected"
                                    color: "#616161"
                                }

                                Text {
                                    id: componentTypeText
                                    text: "Type: -"
                                    color: "#616161"
                                }
                            }
                        }

                        // Position and Size
                        GroupBox {
                            title: "Position & Size"
                            Layout.fillWidth: true

                            GridLayout {
                                columns: 2
                                rowSpacing: 5
                                columnSpacing: 10

                                Text {
                                    text: "X:"
                                    color: "#616161"
                                }

                                TextField {
                                    id: positionX
                                    placeholderText: "X position"
                                    Layout.fillWidth: true
                                }

                                Text {
                                    text: "Y:"
                                    color: "#616161"
                                }

                                TextField {
                                    id: positionY
                                    placeholderText: "Y position"
                                    Layout.fillWidth: true
                                }

                                Text {
                                    text: "Width:"
                                    color: "#616161"
                                }

                                TextField {
                                    id: sizeWidth
                                    placeholderText: "Width"
                                    Layout.fillWidth: true
                                }

                                Text {
                                    text: "Height:"
                                    color: "#616161"
                                }

                                TextField {
                                    id: sizeHeight
                                    placeholderText: "Height"
                                    Layout.fillWidth: true
                                }
                            }
                        }

                        // Tag Binding
                        GroupBox {
                            title: "Tag Binding"
                            Layout.fillWidth: true

                            ColumnLayout {
                                spacing: 5

                                Text {
                                    text: "Tag Name:"
                                    color: "#616161"
                                }

                                TextField {
                                    id: tagNameInput
                                    placeholderText: "Enter tag name"
                                    Layout.fillWidth: true
                                }

                                Button {
                                    text: "Bind to Tag"
                                    onClicked: {
                                        // Tag binding logic
                                    }
                                }
                            }
                        }

                        // Visual Properties
                        GroupBox {
                            title: "Visual Properties"
                            Layout.fillWidth: true

                            ColumnLayout {
                                spacing: 5

                                Text {
                                    text: "Color:"
                                    color: "#616161"
                                }

                                RowLayout {
                                    spacing: 5

                                    Rectangle {
                                        id: colorPreview
                                        width: 30
                                        height: 30
                                        color: "#2196f3"
                                        border.color: "#bdbdbd"
                                        border.width: 1
                                    }

                                    Button {
                                        text: "Change"
                                        onClicked: {
                                            // Color picker logic
                                        }
                                    }
                                }

                                Text {
                                    text: "Opacity:"
                                    color: "#616161"
                                }

                                Slider {
                                    id: opacitySlider
                                    from: 0
                                    to: 1
                                    value: 1
                                    Layout.fillWidth: true
                                }
                            }
                        }
                    }
                }
            }
        }

        // Component Management tab
        Tab {
            title: "Component Management"

            GridLayout {
                anchors.fill: parent
                anchors.margins: 10
                columns: 3
                rowSpacing: 10
                columnSpacing: 10

                // Basic components
                GroupBox {
                    title: "Basic Components"
                    Layout.fillWidth: true
                    Layout.fillHeight: true

                    ColumnLayout {
                        anchors.fill: parent
                        spacing: 10

                        Indicator {
                            width: 60
                            height: 60
                            active: true
                            Layout.alignment: Qt.AlignCenter
                        }

                        PushButton {
                            text: "Button"
                            Layout.alignment: Qt.AlignCenter
                        }

                        TextLabel {
                            labelText: "Label:"
                            valueText: "Value"
                            Layout.fillWidth: true
                        }
                    }
                }

                // Industrial components
                GroupBox {
                    title: "Industrial Components"
                    Layout.fillWidth: true
                    Layout.fillHeight: true

                    ColumnLayout {
                        anchors.fill: parent
                        spacing: 10

                        Valve {
                            width: 100
                            height: 100
                            open: true
                            Layout.alignment: Qt.AlignCenter
                        }

                        Tank {
                            width: 100
                            height: 140
                            level: 0.7
                            Layout.alignment: Qt.AlignCenter
                        }

                        Motor {
                            width: 100
                            height: 100
                            running: true
                            Layout.alignment: Qt.AlignCenter
                        }

                        Pump {
                            width: 100
                            height: 100
                            running: true
                            Layout.alignment: Qt.AlignCenter
                        }
                    }
                }

                // Chart components
                GroupBox {
                    title: "Chart Components"
                    Layout.fillWidth: true
                    Layout.fillHeight: true

                    ColumnLayout {
                        anchors.fill: parent
                        spacing: 10

                        TrendChart {
                            width: parent.width - 20
                            height: 150
                            title: "Trend Chart"
                        }

                        BarChart {
                            width: parent.width - 20
                            height: 150
                            title: "Bar Chart"
                        }
                    }
                }
            }
        }
    }

    // Initialize core modules
    Component.onCompleted: {
        // Core modules will be initialized from C++
        console.log("SCADA System initialized");
    }
}
